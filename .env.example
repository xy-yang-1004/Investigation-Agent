# Server
PORT=5173

# Mock mode:
# - auto: use mock data when no API key exists, otherwise call the real model API
# - true: always use mock data
# - false: always call the real model API
MOCK_MODE=auto

# OpenAI-compatible model API
AI_API_KEY=
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.2

# Some compatible providers do not support response_format.
# Set this to true if your provider rejects JSON mode requests.
DISABLE_RESPONSE_FORMAT=false

# Optional website snapshot collection for URL inputs.
# Keep false for offline demos; set true in trusted local environments.
ENABLE_SITE_FETCH=false
SITE_FETCH_TIMEOUT_MS=5000
